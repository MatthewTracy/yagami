# Yagami environment file. Copy to `.env` and fill in.
#
# Recommended: store API keys in your OS keyring instead of this file:
#   python -m yagami.set_key ANTHROPIC_API_KEY
#   python -m yagami.set_key STABILITY_API_KEY
#   python -m yagami.set_key OPENAI_API_KEY
# Then leave the API_KEY lines below blank or remove them. Yagami reads from
# the keyring first and only falls back to env vars / .env for development.

ANTHROPIC_API_KEY=
STABILITY_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
UPSTREAM_API_KEY=

# Non-secret overrides (also editable in config/yagami.toml or via the
# Settings modal in the UI):
YAGAMI_OLLAMA_URL=http://localhost:11434
YAGAMI_OLLAMA_MODEL=llama3.2:3b-instruct-q4_K_M
# Use private_network only when the named Ollama service is inside a network
# boundary trusted with prompts, classifier input, and embeddings.
YAGAMI_OLLAMA_TRUST_ZONE=device
YAGAMI_CLAUDE_MODEL=claude-sonnet-4-6
YAGAMI_CONFIG_PATH=config/yagami.toml

# Headless gateway identity. JSON supports multiple separation-of-duties keys
# for one project; see docs/gateway.md. Never commit real values.
YAGAMI_API_KEYS=
YAGAMI_REQUIRE_AUTH=false
YAGAMI_HEADLESS=false
YAGAMI_MCP_SERVER_ENABLED=true

# Optional OIDC workload identity. The JWT must include `sub`, an expiry,
# `yagami_project`, and the configured roles/scope claims.
YAGAMI_OIDC_ISSUER=
YAGAMI_OIDC_AUDIENCE=
YAGAMI_OIDC_JWKS_URL=
YAGAMI_OIDC_PROJECT_CLAIM=yagami_project
YAGAMI_OIDC_ROLES_CLAIM=roles
YAGAMI_OIDC_SCOPES_CLAIM=scope

# Generate separate values with `yagami-keygen`. The transform key must be
# URL-safe base64; the audit key is an independent HMAC secret.
YAGAMI_TRANSFORM_KEY=
YAGAMI_AUDIT_KEY=
YAGAMI_AUDIT_REQUIRED=false

# In production, prefer BYOK references over direct values above. Supported
# providers are env:VARIABLE, file:/mounted/secret, and keyring:service/account.
YAGAMI_TRANSFORM_KEY_REF=
YAGAMI_AUDIT_KEY_REF=

# Optional content-free audit event delivery to a SIEM webhook. Only HTTPS
# endpoints (or loopback HTTP) are accepted. `splunk_hec` uses Splunk's event
# envelope and Authorization header; `json` uses a normal bearer token.
YAGAMI_AUDIT_SINK_URL=
YAGAMI_AUDIT_SINK_TOKEN_REF=
YAGAMI_AUDIT_SINK_FORMAT=json
YAGAMI_AUDIT_SINK_REQUIRED=false
YAGAMI_AUDIT_SINK_TIMEOUT_SECONDS=5

# Optional outbound lifecycle notifications. These never contain the one-time
# approval token or user/model content. Formats: json, slack, teams.
YAGAMI_APPROVAL_WEBHOOK_URL=
YAGAMI_APPROVAL_WEBHOOK_FORMAT=json
YAGAMI_APPROVAL_WEBHOOK_TIMEOUT_SECONDS=5

# Optional Microsoft Presidio Analyzer REST integration. Loopback is accepted
# by default; remote endpoints require explicit opt-in and HTTPS because Yagami
# sends request context to the analyzer. Fail-closed keeps analyzer outages local.
YAGAMI_PRESIDIO_URL=
YAGAMI_PRESIDIO_LANGUAGE=en
YAGAMI_PRESIDIO_SCORE_THRESHOLD=0.5
YAGAMI_PRESIDIO_TIMEOUT_SECONDS=5
YAGAMI_PRESIDIO_FAIL_CLOSED=true
YAGAMI_PRESIDIO_ALLOW_REMOTE=false
YAGAMI_PRESIDIO_TOKEN_REF=
