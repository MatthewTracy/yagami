# Yagami environment file. Copy to `.env` and fill in.
#
# Recommended: store API keys in your OS keyring instead of this file:
#   python -m yagami.set_key ANTHROPIC_API_KEY
#   python -m yagami.set_key STABILITY_API_KEY
#   python -m yagami.set_key OPENAI_API_KEY
# Then leave the API_KEY lines below blank or remove them. Yagami reads from
# the keyring first and only falls back to env vars / .env for development.

ANTHROPIC_API_KEY=
STABILITY_API_KEY=
OPENAI_API_KEY=

# Non-secret overrides (also editable in config/yagami.toml or via the
# Settings modal in the UI):
YAGAMI_OLLAMA_URL=http://localhost:11434
YAGAMI_OLLAMA_MODEL=llama3.2:3b-instruct-q4_K_M
YAGAMI_CLAUDE_MODEL=claude-sonnet-4-6
YAGAMI_CONFIG_PATH=config/yagami.toml
