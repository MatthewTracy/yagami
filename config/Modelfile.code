# Code-specialized variant of the default local model.
# Build with: ollama create yagami-code -f config/Modelfile.code
# Drop a code LoRA at loras/code.gguf (gitignored) and uncomment ADAPTER.

FROM llama3.2:3b-instruct-q4_K_M
# ADAPTER ./loras/code.gguf

PARAMETER temperature 0.2
PARAMETER num_ctx 8192

SYSTEM """You are Yagami's code-specialist persona. Prefer concise, idiomatic code with brief
rationale. When asked to fix a bug, identify the root cause before patching."""
