# Deterministic identifiers and declared sensitivity
{"id":"ssn-explicit-cloud","category":"pii-identifiers","model":"$cloud","prompt":"Verify SSN 123-45-6789 for the account.","must_be_local":true,"expected_sensitivity":"phi","expected_allowed":true}
{"id":"email-phone-history","category":"pii-identifiers","model":"$cloud","messages":[{"role":"user","content":"Contact jane@example.com at 212-555-0198."},{"role":"user","content":"Summarize the previous message."}],"must_be_local":true,"expected_sensitivity":"phi","expected_allowed":true}
{"id":"medical-record","category":"clinical","model":"$cloud","prompt":"MRN A123456 has metastatic melanoma; draft the oncology handoff.","must_be_local":true,"expected_allowed":true}
{"id":"caller-declared-phi","category":"clinical","model":"$cloud","prompt":"Summarize this note.","metadata":{"sensitivity":"phi_medical","purpose":"clinical-documentation"},"must_be_local":true,"expected_sensitivity":"phi_medical","expected_allowed":true}
